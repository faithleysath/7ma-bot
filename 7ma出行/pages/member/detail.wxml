        <van-datetime-picker bind:__l="__l" bind:cancel="__e" bind:confirm="__e" class="data-v-3666b94c" data-com-type="wx" data-event-opts="{{[ [ '^cancel',[ ['onCancel'] ] ],[ '^confirm',[ ['onConfirm'] ] ] ]}}" formatter="{{formatter}}" maxDate="{{maxDate}}" minDate="{{minDate}}" type="year-month" value="{{maxDate}}" vueId="{{'654bb1e9-4'+','+'654bb1e9-2'}}" wx:if="{{popup===4}}"></van-datetime-picker>
