                <label class="content _span data-v-3666b94c" wx:if="{{user.sex===0}}">请选择性别</label>
                <block wx:else>
                    <label class="content _span data-v-3666b94c" wx:if="{{user.sex===1}}">男</label>
                    <block wx:else>
                        <label class="content _span data-v-3666b94c" wx:if="{{user.sex===2}}">女</label>
                    </block>
