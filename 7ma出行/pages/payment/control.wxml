                <icon class="data-v-4f0d0b05" color="#ec3f4c" type="success"></icon>
            </view>
        </view>
    </view>
    <view class="fixed bottom0 left0 w_100 box-sizing pl15 pr15 data-v-4f0d0b05">
        <view bindtap="__e" class="br10 color-f line100 text-center data-v-4f0d0b05" data-event-opts="{{[ [ 'tap',[ [ 'goWxAppPay',['$event'] ] ] ] ]}}" style="background:#ec3f4c;">立即支付</view>
