            <view class="data-v-4f0d0b05">
                <image class="block data-v-4f0d0b05" mode="scaleToFill" src="https://img2.7mate.cn/alioss0054b9de6f154611b30ce33493e2fb5a.png" style="width:60rpx;height:60rpx;"></image>
            </view>
            <view class="pl20 data-v-4f0d0b05">微信支付</view>
