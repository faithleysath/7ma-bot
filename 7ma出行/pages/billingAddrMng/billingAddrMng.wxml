<view class="container data-v-61563d12">
    <my-header bgColor="{{['#FF6C58','#FF4C52']}}" bind:__l="__l" bind:back="__e" class="data-v-61563d12" data-event-opts="{{[ [ '^back',[ ['back'] ] ] ]}}" fontColor="#fff" title="发票抬头管理" vueId="919e4780-1"></my-header>
    <view class="content data-v-61563d12">
