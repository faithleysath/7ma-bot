                </view>
            </view>
        </view>
    </view>
    <view class="fixed w_100 left0 bottom0 row-center pb100 data-v-61563d12">
        <view bindtap="__e" class="row-center color-f font30 br40 data-v-61563d12" data-event-opts="{{[ [ 'tap',[ [ 'go',['/pages/billingAdd/billingAdd'] ] ] ] ]}}" style="width:600rpx;height:80rpx;background:linear-gradient(135deg, #FF4C52, #FF6C58);box-shadow:0 5rpx 20rpx 0 rgba(95, 31, 33, 0.2);">
