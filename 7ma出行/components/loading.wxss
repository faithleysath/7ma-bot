.ws_loading {
    color: #f1f1f1;
    font-size: 24rpx;
    height: 1000rpx;
    text-align: center;
    width: 1000rpx;
    z-index: 10
}

.ws_loading .container {
    background: rgba(51,51,51,.7);
    height: 260rpx;
    left: 50%;
    margin-left: -130rpx;
    margin-top: -130rpx;
    position: absolute;
    top: 50%;
    width: 260rpx
}

.ws_loading .container .img {
    height: 160rpx;
    width: 160rpx
}
